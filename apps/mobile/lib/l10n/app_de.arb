  "successionPatrimoinePhase1Action3": "Gemeinsame Bankkonten bei Bedarf sperren",
  "successionPatrimoinePhase1Action4": "Den Notar kontaktieren, wenn die Person ein Testament hatte",
  "successionPatrimoinePhase2Timeframe": "T+8 bis T+30",
