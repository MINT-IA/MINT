  "successionPatrimoinePhase1Action4": "Contactar o notário se a pessoa tinha testamento",
  "successionPatrimoinePhase2Timeframe": "D+8 a D+30",
  "successionPatrimoinePhase2Title": "Procedimentos administrativos",
  "successionPatrimoinePhase2Action1": "Solicitar as rendas de sobrevivência AVS (LAVS art. 23)",
  "successionPatrimoinePhase2Action2": "Contactar a caixa LPP para o capital por falecimento",
