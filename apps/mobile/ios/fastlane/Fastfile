require "base64"

# MINT iOS — Fastlane configuration
# Usage:
#   cd apps/mobile/ios
#   bundle exec fastlane beta
#
# Required environment variables (set as GitHub Secrets):
#   APP_STORE_CONNECT_API_KEY_ID      — App Store Connect API Key ID
#   APP_STORE_CONNECT_ISSUER_ID       — App Store Connect Issuer ID
#   APP_STORE_CONNECT_API_KEY_CONTENT — App Store Connect API Key (.p8 content)
#   MATCH_PASSWORD                    — Password to decrypt certificates repo
#   MATCH_GIT_URL                     — Git repo URL for match certificates
#   KEYCHAIN_PASSWORD                 — Temporary keychain password (CI only)

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    key_id = [
      ENV["APP_STORE_CONNECT_API_KEY_ID"],
      ENV["APP_STORE_KEY_ID"],
      ENV["ASC_KEY_ID"],
    ].map { |v| v.to_s.strip }.find { |v| !v.empty? }

    issuer_id = [
      ENV["APP_STORE_CONNECT_ISSUER_ID"],
      ENV["APP_STORE_ISSUER_ID"],
      ENV["ASC_ISSUER_ID"],
    ].map { |v| v.to_s.strip }.find { |v| !v.empty? }

    raw_key_content = [
      ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      ENV["APP_STORE_CONNECT_API_KEY"],
      ENV["APP_STORE_CONNECT_PRIVATE_KEY"],
      ENV["ASC_API_KEY_CONTENT"],
    ].map { |v| v.to_s.strip }.find { |v| !v.empty? }

    UI.user_error!("Missing App Store key id (APP_STORE_CONNECT_API_KEY_ID)") if key_id.to_s.empty?
    UI.user_error!("Missing App Store issuer id (APP_STORE_CONNECT_ISSUER_ID)") if issuer_id.to_s.empty?
    UI.user_error!("Missing App Store private key content (APP_STORE_CONNECT_API_KEY_CONTENT)") if raw_key_content.to_s.empty?

    # Accept either plain .p8 content or base64-encoded .p8, and normalize escaped newlines.
    normalized_key_content = raw_key_content.gsub('\n', "\n")
    unless normalized_key_content.include?("-----BEGIN PRIVATE KEY-----")
      begin
        decoded = Base64.strict_decode64(normalized_key_content)
        normalized_key_content = decoded
      rescue ArgumentError
        UI.user_error!("APP_STORE_CONNECT_API_KEY_CONTENT must be a .p8 key or base64-encoded .p8 key")
      end
    end

    unless normalized_key_content.include?("-----BEGIN PRIVATE KEY-----") &&
           normalized_key_content.include?("-----END PRIVATE KEY-----")
      UI.user_error!("APP_STORE_CONNECT_API_KEY_CONTENT does not contain a valid .p8 private key")
    end

    # ── 1. App Store Connect API auth (no interactive login) ──
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: normalized_key_content,
      is_key_content_base64: false,
      in_house: false,
    )

    # ── 2. Setup temporary keychain (CI environment) ──
    if ENV["CI"]
      keychain_pw = ENV["KEYCHAIN_PASSWORD"] || "ci_temp_password"
      # Force-remove any stale keychain from previous CI runs
      sh("security", "delete-keychain", "ci_keychain", raise_on_error: false) rescue nil
      create_keychain(
        name: "ci_keychain",
        password: keychain_pw,
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false,
        lock_after_timeout: false,
        add_to_search_list: true,
      )
    end

    # ── 3. Fetch signing certificates + profiles ──
    match_params = {
      type: "appstore",
      app_identifier: "ch.mint.app",
      git_url: ENV["MATCH_GIT_URL"],
      api_key: api_key,
      readonly: true,
    }
    if ENV["CI"]
      match_params[:keychain_name] = "ci_keychain"
      match_params[:keychain_password] = keychain_pw
      # CI needs explicit auth to clone the private certificates repo
      if ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
        match_params[:git_basic_authorization] = ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
      end
    end
    match(match_params)

    # Ensure xcodebuild can find the signing identity
    if ENV["CI"]
      sh("security", "set-key-partition-list", "-S", "apple-tool:,apple:,codesign:", "-s", "-k", keychain_pw, File.expand_path("~/Library/Keychains/ci_keychain-db"))
    end

    # ── 4. Auto-increment build number ──
    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key) + 1,
      xcodeproj: "Runner.xcodeproj",
    )

    # Work around google_fonts const-map incompatibility on some CI runtimes.
    # sh() runs from ios/fastlane/, so ../../scripts/ reaches apps/mobile/scripts/
    sh("../../scripts/patch_google_fonts_const_map.sh")

    # ── 5. Build the Flutter IPA ──
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "../build/ios",
      output_name: "Mint.ipa",
    )

    # ── 6. Upload to TestFlight ──
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: true,
      groups: ["Beta Testeurs"],  # <-- ton groupe TestFlight
      changelog: "Nouvelle version automatique depuis CI/CD",
    )
  end

  desc "Register devices + refresh profiles"
  lane :refresh_profiles do
    match(
      type: "appstore",
      app_identifier: "ch.mint.app",
      git_url: ENV["MATCH_GIT_URL"],
      force_for_new_devices: true,
    )
  end

  desc "Initialize Match certificates (run once locally)"
  lane :setup_match do
    raw = ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]
    normalized = raw.gsub('\n', "\n")
    unless normalized.include?("-----BEGIN PRIVATE KEY-----")
      normalized = Base64.strict_decode64(normalized)
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: normalized,
      is_key_content_base64: false,
      in_house: false,
    )

    match(
      type: "appstore",
      app_identifier: "ch.mint.app",
      team_id: "7F5UDGYS5H",
      api_key: api_key,
      git_url: ENV["MATCH_GIT_URL"],
    )
  end
end
