# MINT Backend Configuration
# Copy this file to .env and adjust values for your environment.

# Environment: development | staging | production
ENVIRONMENT=development

# Database (PostgreSQL for production, SQLite for local dev)
DATABASE_URL=postgresql://mint:mint@localhost:5432/mint

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
AUTH_REQUIRE_EMAIL_VERIFICATION=0
AUTH_UNVERIFIED_PURGE_DAYS=7
AUTH_AUTO_PURGE_ON_STARTUP=0
AUTH_ADMIN_EMAIL_ALLOWLIST=

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Redis (used for rate limiting; leave empty for in-memory fallback)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Transactional email (SMTP)
EMAIL_SEND_ENABLED=false
EMAIL_FROM=no-reply@mint.ch
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
FRONTEND_BASE_URL=https://app.mint.ch

# Billing hardening flags
BILLING_ALLOW_CLIENT_APPLE_VERIFY=0
APPLE_WEBHOOK_SHARED_SECRET=

# Feature Flags (all default to false)
FF_ENABLE_COUPLE_PLUS_TIER=false
FF_ENABLE_SLM_NARRATIVES=false
FF_ENABLE_DECISION_SCAFFOLD=false
FF_VALEUR_LOCATIVE_2028_REFORM=false
FF_SAFE_MODE_DEGRADED=false
FF_ENABLE_BLINK_PRODUCTION=false
FF_ENABLE_CAISSE_PENSION_API=false
FF_ENABLE_EXPERT_TIER=false
FF_ENABLE_ADMIN_SCREENS=false
FF_ENABLE_AVS_INSTITUTIONAL=false
INTERNAL_ACCESS_ENABLED=false
INTERNAL_ACCESS_ALLOWLIST=

# Gunicorn workers (production)
WORKERS=4
